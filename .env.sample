# GovKit environment configuration — copy to .env and fill in.
# NEVER commit a real .env. All values below are placeholders.

# --- Core Django ---
DEBUG=true
SECRET_KEY=change-me-to-a-long-random-string
ALLOWED_HOSTS=localhost,127.0.0.1
# Comma-separated origins trusted for unsafe CSRF requests (needed behind a proxy/https).
CSRF_TRUSTED_ORIGINS=

# Comma-separated browser origins allowed to read the JSON API cross-origin with
# the member's session cookie (the cohort dash). Empty disables CORS entirely.
# Cohort value: https://workers.vc,https://www.workers.vc
CORS_ALLOWED_ORIGINS=

# Hostnames (not origins) a post-login ?next= may redirect to as an absolute https URL,
# so the dash sign-in chip can round-trip through GovKit's OIDC login.
# Cohort value: workers.vc,www.workers.vc   Empty = only relative next paths allowed.
LOGIN_NEXT_ALLOWED_HOSTS=

# Server-side cache TTL (seconds) for the live open-tasks proxy endpoint.
GOVKIT_OPEN_TASKS_CACHE_SECONDS=60

# Deploy behind a path prefix (e.g. demos.example.com/govkit/). Empty for local dev.
BASE_PATH=

# --- Database ---
# Compose supplies this automatically for the bundled Postgres. Override for external DB.
DATABASE_URL=postgres://govkit:govkit@db:5432/govkit

# --- Symmetric encryption for stored task-source API tokens (Fernet key) ---
# Generate with: python -c "from cryptography.fernet import Fernet; print(Fernet.generate_key().decode())"
GOVKIT_SECRET_KEY=

# --- LinkedTrust OIDC (DEFAULT login — wired by the auth agent) ---
LINKEDTRUST_URL=https://live.linkedtrust.us
LINKEDTRUST_CLIENT_ID=
LINKEDTRUST_CLIENT_SECRET=
LINKEDTRUST_SCOPES=openid email profile trust
LINKEDTRUST_FRONTEND_URL=
LINKEDTRUST_FRONTEND_CALLBACK=/oauth/callback

# --- Google OAuth (secondary login — wired by the auth agent) ---
GOOGLE_OAUTH_CLIENT_ID=
GOOGLE_OAUTH_CLIENT_SECRET=

# --- Dev-only login seam (allows a password login form while OAuth is unwired) ---
# Set to false in any real deployment. Has no effect unless DEBUG is also considered by the auth agent.
GOVKIT_DEV_LOGIN=true

# --- Doorway invites (two-step magic links) ---
# Shared secret for the doorway's server-to-server invite API. Empty = endpoints disabled.
GOVKIT_S2S_TOKEN=
# Base of the public doorway page; magic link = <DOORWAY_BASE_URL><code>/.
# Empty hides the doorway option in the invite mint UI.
DOORWAY_BASE_URL=https://linkedtrust.us/earnedgov/i/

# --- Amebo team registry (server-to-server) ---
# Accepted memberships are reported to POST <AMEBO_BASE_URL>/api/orgs/provision so
# amebo provisions the person across the team's tools. Either value empty disables
# the reporting (no-op); amebo's reconcile loop covers any drift.
AMEBO_BASE_URL=
AMEBO_S2S_TOKEN=

# --- Cohort chrome -----------------------------------------------------------
# The thin cross-app cohort menu, served by the doorway. Empty = standalone.
# Cohort value: https://workers.vc/static/embed/cohort-nav.js
COHORT_NAV_SRC=
